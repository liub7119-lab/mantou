# ======================================
# 辅导员工作辅助平台 - 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# ======================================

# 调试模式
DEBUG=true

# LLM 配置（二选一）
LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Gemini 配置
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# CORS 允许的前端地址
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
